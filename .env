# NousAI Companion — Environment Variables
# Copy this file to .env.local for local overrides (never commit real keys)

# Valyu API — get your key at https://valyu.network
# Used by FactCheckTool (web search) and CourseGenTool (academic search)
VITE_VALYU_API_KEY=

# Google OAuth2 Client ID — get from https://console.developers.google.com
# Used by Google Calendar integration in CalendarPage
# Alternative: set in the app UI (Calendar → Google Calendar tab → Setup)
VITE_GOOGLE_CLIENT_ID=
