{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx playwright install --with-deps chromium 2>&1 || true",
            "timeout": 120
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/johnn/Desktop/NousAI-App/scripts/clear-pwa-cache.js\"",
            "conditions": {
              "toolInput.command": ".*vercel.*--prod.*"
            }
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npx playwright*)",
      "Bash(npx vite preview*)",
      "Bash(npm run build*)"
    ]
  }
}
